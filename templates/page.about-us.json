      "blocks": {
        "intro-heading": {
          "type": "heading",
          "settings": {
            "heading": "This Is Us",
            "heading_size": "h0"
          }
        },
        "intro-text": {
          "type": "text",
          "settings": {
            "text": "<p>A steadily growing team – mostly woman. Even though we don't focus on a woman only team, we just happened to be one (almost). Everyone of us has a super power and all of them combined makes us quite strong. Before we introduce everyone of the team, let us share our values and beliefs with you.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "intro-heading",
        "intro-text"
      ],
      "settings": {
