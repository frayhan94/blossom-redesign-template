    "16370500399332968f": {
      "type": "image-with-text",
      "blocks": {
        "1637050039f8c4dc12-0": {
          "type": "heading",
          "settings": {
            "heading": "christmas is coming"
          }
        },
        "1637050039f8c4dc12-1": {
          "type": "text",
          "settings": {
            "text": "<p>Get ready for the festive season. We have some Bandana designs, that will make you feel even more christmassy. <br/>Imagine mulled wine, a fire pit and getting cozy with your dog. </p>"
          }
        },
        "1637050039f8c4dc12-2": {
          "type": "button",
          "settings": {
