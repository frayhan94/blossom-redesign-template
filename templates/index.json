    "16370504048fc804df": {
      "type": "multicolumn",
      "blocks": {
        "1637050404a4a6b5ae-0": {
          "type": "column",
          "settings": {
            "title": "Locally produced in Indonesia",
            "text": "<p>Each of our suppliers & producers are treated like a part of our family. We put in significant time & effort to find the perfect fit, in terms of values & quality, for each element of our supply chain. Most of our suppliers and partners are local female business owners and we love having the opportunity to support them!</p>"
          }
        },
        "1637050404a4a6b5ae-1": {
          "type": "column",
          "settings": {
            "title": "Handpicked materials",
            "text": "<p>We always first consider sustainability when choosing the materials used to make our products. Achieving 100% sustainability is impossible, but with every product we produce, we try our best to be as eco-friendly as possible. </p>"
          }
        },
        "1637050404a4a6b5ae-2": {
          "type": "column",
          "settings": {
            "title": "No plastic",
            "text": "<p>We have a no plastic policy. We have an agreement with our producers to not use single-use plastic wrap and we carefully pick our packaging to avoid usage of plastic.</p>"
          }
        },
        "dc97a7ca-0a7d-4326-a8e3-02b99c0d3532": {
          "type": "column",
          "settings": {
            "title": "Impact",
            "text": "<p>We donate 5% of our profits to help street dogs in need. We rescue dogs ourselves & work together with local foundations to rescue Bali street dogs and find them their forever homes. Our brand focuses on raising awareness around animal welfare and pollution.</p>"
          }
        }
      },
      "block_order": [
        "1637050404a4a6b5ae-0",
        "1637050404a4a6b5ae-1",
        "1637050404a4a6b5ae-2",
        "dc97a7ca-0a7d-4326-a8e3-02b99c0d3532"
